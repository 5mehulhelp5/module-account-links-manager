<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>eTechFlow</label>
        </tab>
        <section id="etechflow_accountlinks"
                 translate="label" type="text" sortOrder="160"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Customer Dashboard Links Manager</label>
            <tab>etechflow</tab>
            <resource>ETechFlow_AccountLinksManager::config</resource>

            <group id="license" translate="label" type="text" sortOrder="5"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>

                <field id="license_key" translate="label comment tooltip" type="text"
                       sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <tooltip>Subscription key (SP-XXXX-XXXX-XXXX-XXXX) from your eTechFlow portal.</tooltip>
                    <comment><![CDATA[
                        Enter your subscription key from your portal.<br/>
                        Format: <code>SP-XXXX-XXXX-XXXX-XXXX</code><br/>
                        The key is validated against your domain <strong>and</strong> your server IP — both must match.
                    ]]></comment>
                </field>


                <field id="portal_url" translate="label comment tooltip" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL (browser)</label>
                    <tooltip>URL of your eTechFlow licensing portal — opened in the admin browser for plan selection.</tooltip>
                    <comment><![CDATA[
                        The portal URL opened in your browser when you click "Subscribe" on the gate page.<br/>
                        For local development: <code>http://127.0.0.1:5000</code><br/>
                        For production: your publicly deployed portal URL.
                    ]]></comment>
                </field>

                <field id="portal_api_url" translate="label comment tooltip" type="text"
                       sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Validation API URL (server)</label>
                    <tooltip>URL used by the Magento server to validate SP-XXXX keys. Must be reachable from the server (not localhost).</tooltip>
                    <comment><![CDATA[
                        URL called by the Magento <em>server</em> to validate subscription keys.<br/>
                        Must be publicly reachable (not <code>127.0.0.1</code>).<br/>
                        Use ngrok for local testing: <code>https://your-ngrok-url.ngrok-free.app</code><br/>
                        Leave blank to use the Portal URL above as fallback (only works if the portal is publicly accessible).
                    ]]></comment>
                </field>
            </group>

            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>

                <field id="enabled" translate="label comment tooltip" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <tooltip>Turn the link filter on or off without uninstalling.</tooltip>
                    <comment><![CDATA[
                        <strong>Yes</strong> = module filters the customer My Account sidebar.<br/>
                        <strong>No</strong> (default) = module is dormant; sidebar shows all links.
                    ]]></comment>
                </field>

                <field id="mode" translate="label comment" type="select"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Action</label>
                    <source_model>ETechFlow\AccountLinksManager\Model\Source\Mode</source_model>
                    <comment><![CDATA[
                        <strong>Hide selected links</strong>: chosen links are hidden.<br/>
                        <strong>Show only selected links</strong>: only chosen links are visible.
                    ]]></comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="hidden_links" translate="label comment" type="multiselect"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Links</label>
                    <source_model>ETechFlow\AccountLinksManager\Model\Source\AvailableLinks</source_model>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <field id="extra_block_names" translate="label comment" type="textarea"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Extra block names (one per line)</label>
                    <depends><field id="enabled">1</field></depends>
                </field>
            </group>
        
    </section>
    </system>
</config>