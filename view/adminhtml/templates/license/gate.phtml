<script>
var _etfPlan = '';
var _etfCreateUrl = '<?= $block->escapeJs($createSessionUrl) ?>';
var _etfPlansUrl  = '<?= $block->escapeJs($plansUrl) ?>';

function etfEsc(s){ var d=document.createElement('div'); d.textContent=s==null?'':String(s); return d.innerHTML; }
function etfFeatList(text){
    if(!text) return '<li>Hide any My Account links</li><li>Multi-store</li>';
    var t = String(text).replace(/^[^—-]*[—-]\s*/, '');
    var parts = t.split(/,\s*/).filter(function(x){return x.trim();}).slice(0,4);
    if(!parts.length) return '<li>Hide any My Account links</li>';
    return parts.map(function(p){return '<li>'+etfEsc(p.trim())+'</li>';}).join('');
}
function etfRenderPlans(data){
    var wrap = document.getElementById('etf-plans');
    var plans = (data && data.plans) || [];
    if(!plans.length){ etfPlansError(); return; }
    var oneTime = (data.mode === 'one_time');
    var html = '';
    plans.forEach(function(p){
        var popular = (!oneTime && p.period === 'monthly');
        var title = oneTime ? (p.name || 'Lifetime License')
                   : ({week:'Weekly',month:'Monthly',year:'Yearly'}[p.period_label] || etfEsc(p.name));
        var unit  = oneTime ? ' once' : ('/' + etfEsc(p.period_label));
        var desc  = oneTime ? 'Pay once — never expires.'
                   : ({week:'Short-term or trying it out',month:'The standard plan',year:'Best value — 2 months free'}[p.period_label] || '');
        var priceDisp = '$' + p.price + (oneTime ? ' once' : '/' + p.period_label);
        html += '<div class="etf-plan-card'+(popular?' popular':'')+'">'
              + (popular ? '<span class="etf-popular-badge">Most Popular</span>' : '')
              + (oneTime ? '<span class="etf-popular-badge">Lifetime</span>' : '')
              + '<p class="etf-plan-name">'+etfEsc(title)+'</p>'
              + '<p class="etf-plan-price">$'+etfEsc(p.price)+'<span>'+unit+'</span></p>'
              + '<p class="etf-plan-desc">'+etfEsc(desc)+'</p>'
              + '<ul class="etf-plan-features">'+etfFeatList(p.features)+'</ul>'
              + '<button class="etf-btn-sub" data-slug="'+etfEsc(p.slug)+'" data-name="'+etfEsc(title)+'" data-price="'+etfEsc(priceDisp)+'">Subscribe &rarr;</button>'
              + '</div>';
    });
    wrap.innerHTML = html;
    wrap.querySelectorAll('.etf-btn-sub').forEach(function(b){
        b.addEventListener('click', function(){ etfSelectPlan(b.dataset.slug, b.dataset.name, b.dataset.price); });
    });
}
function etfPlansError(){
    document.getElementById('etf-plans').innerHTML =
      '<div style="grid-column:1/-1;text-align:center;color:rgba(255,255,255,.5);font-size:.85rem;padding:18px;">Plans are temporarily unavailable. Use the “enter license key” link below.</div>';
}
(function(){
    if(!_etfPlansUrl){ etfPlansError(); return; }
    fetch(_etfPlansUrl, { headers:{ 'Accept':'application/json','ngrok-skip-browser-warning':'1' } })
      .then(function(r){ return r.json(); }).then(etfRenderPlans).catch(etfPlansError);
})();

function etfSelectPlan(plan, name, price) {
    _etfPlan = plan;
    document.getElementById('etf-plan-name-label').textContent = name;
    document.getElementById('etf-plan-price-label').textContent = price;
    var box = document.getElementById('etf-checkout');
    box.style.display = 'block';
    box.scrollIntoView({behavior: 'smooth', block: 'start'});
    document.getElementById('etf-name').focus();
}

function etfBack() {
    document.getElementById('etf-checkout').style.display = 'none';
    window.scrollTo({top: 0, behavior: 'smooth'});
}

async function etfProceedToPayment() {
    var name  = document.getElementById('etf-name').value.trim();
    var email = document.getElementById('etf-email').value.trim();

    if (!name) { alert('Please enter your full name.'); document.getElementById('etf-name').focus(); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { alert('Please enter a valid email address.'); document.getElementById('etf-email').focus(); return; }

    var btn = document.getElementById('etf-pay-btn');
    var orig = btn.textContent;
    btn.textContent = 'Creating payment session…';
    btn.disabled = true;

    try {
        var body = new URLSearchParams({
            plan: _etfPlan,
            name: name,
            email: email,
            form_key: '<?= $block->escapeJs($block->getFormKey()) ?>'
        });
        var resp = await fetch(_etfCreateUrl, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: body.toString()
        });
        var rawText = await resp.text();
        var data;
        try {
            data = JSON.parse(rawText);
        } catch(parseErr) {
            // Show first 300 chars of the raw response for debugging
            alert('Server response (debug): ' + rawText.substring(0, 300));
            btn.textContent = orig;
            btn.disabled = false;
            return;
        }

        if (data.error) {
            alert('Error: ' + data.error);
            btn.textContent = orig;
            btn.disabled = false;
        } else if (data.url) {
            btn.textContent = 'Redirecting to checkout…';
            window.location.href = data.url;
        } else {
            alert('Unexpected response. Please try again.');
            btn.textContent = orig;
            btn.disabled = false;
        }
    } catch(e) {
        alert('Network error: ' + e.message);
        btn.textContent = orig;
        btn.disabled = false;
    }
}
</script>